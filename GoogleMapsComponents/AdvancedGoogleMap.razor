@using GoogleMapsComponents.Maps
@using Microsoft.JSInterop
@implements IAsyncDisposable

<GoogleMap @ref="@MapRef" Id="@Id" Height="@Height" Options="@Options" OnAfterInit="@AfterInit" CssClass="@CssClass" />

@if (MapRef?.InteropObject is not null)
{
    <CascadingValue Name="Map" Value="@this" IsFixed="true">
        @ChildContent
    </CascadingValue>
}

@code {
    /// <summary>
    /// The underlying GoogleMap component reference. Exposed to allow direct access to the map interop object.
    /// </summary>
    public GoogleMap? MapRef;

    /// <summary>
    /// Gets the underlying Google Maps JavaScript interop object.
    /// </summary>
    public Map? InteropObject => MapRef?.InteropObject;

    internal Guid? MapId => MapRef?.InteropObject.Guid;

    /// <summary>
    /// Gets the total number of markers currently added to the map.
    /// </summary>
    public int MarkerCount => _mapComponents.Count;

    /// <summary>
    /// Gets all marker components currently added to the map.
    /// </summary>
    public IEnumerable<MarkerComponent> Markers => _mapComponents.Select(x => x.Value);
    private readonly Dictionary<Guid, MarkerComponent> _mapComponents = [];


    /// <summary>
    /// Gets the total number of polygons currently added to the map.
    /// </summary>
    public int PolygonCount => _mapPolygonComponents.Count;

    /// <summary>
    /// Gets all polygon components currently added to the map.
    /// </summary>
    public IEnumerable<PolygonComponent> Polygons => _mapPolygonComponents.Select(x => x.Value);
    private readonly Dictionary<Guid, PolygonComponent> _mapPolygonComponents = [];

    internal DotNetObjectReference<AdvancedGoogleMap>? CallbackRef;

    /// <summary>
    /// The HTML id attribute for the map container element.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// Configuration options for the Google Map.
    /// </summary>
    [Parameter]
    public MapOptions? Options { get; set; }

    /// <summary>
    /// Callback invoked after the map has been initialized.
    /// </summary>
    [Parameter]
    public EventCallback OnAfterInit { get; set; }

    /// <summary>
    /// Callback invoked when markers are added or removed from the map.
    /// </summary>
    [Parameter]
    public EventCallback OnMarkersChanged { get; set; }

    /// <summary>
    /// Callback invoked when polygons are added or removed from the map.
    /// </summary>
    [Parameter]
    public EventCallback OnPolygonsChanged { get; set; }


    /// <summary>
    /// CSS class name(s) to apply to the map container element.
    /// </summary>
    [Parameter]
    public string? CssClass { get; set; }

    /// <summary>
    /// CSS height value for the map container (e.g., "400px", "100%").
    /// </summary>
    [Parameter]
    public string? Height { get; set; }

    /// <summary>
    /// Child content containing map components (markers, polygons, etc.).
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// 
    /// </summary>
    protected override void OnInitialized()
    {
        CallbackRef = DotNetObjectReference.Create(this);
        base.OnInitialized();
    }

    private async Task AfterInit()
    {
        await OnAfterInit.InvokeAsync();
    }

    /// <summary>
    /// Invoked from JavaScript when a marker is clicked. Routes the event to the corresponding marker component.
    /// </summary>
    /// <param name="markerId">The unique identifier of the clicked marker.</param>
    [JSInvokable]
    public async Task OnMarkerClicked(Guid markerId)
    {
        if (_mapComponents.TryGetValue(markerId, out var markerComponent))
        {
            await markerComponent.MarkerClicked();
        }
    }

    /// <summary>
    /// Invoked from JavaScript when a marker is dragged. Routes the event to the corresponding marker component.
    /// </summary>
    /// <param name="markerId">The unique identifier of the dragged marker.</param>
    /// <param name="position">The new position of the marker.</param>
    [JSInvokable]
    public async Task OnMarkerDrag(Guid markerId, LatLngLiteral position)
    {
        if (_mapComponents.TryGetValue(markerId, out var markerComponent))
        {
            await markerComponent.MarkerDragged(position);
        }
    }

    /// <summary>
    /// Invoked from JavaScript when the mouse enters a marker. Routes the event to the corresponding marker component.
    /// </summary>
    /// <param name="markerId">The unique identifier of the marker.</param>
    [JSInvokable]
    public async Task OnMarkerMouseOver(Guid markerId)
    {
        if (_mapComponents.TryGetValue(markerId, out var markerComponent))
        {
            await markerComponent.MarkerMouseOver();
        }
    }

    /// <summary>
    /// Invoked from JavaScript when the mouse leaves a marker. Routes the event to the corresponding marker component.
    /// </summary>
    /// <param name="markerId">The unique identifier of the marker.</param>
    [JSInvokable]
    public async Task OnMarkerMouseOut(Guid markerId)
    {
        if (_mapComponents.TryGetValue(markerId, out var markerComponent))
        {
            await markerComponent.MarkerMouseOut();
        }
    }

    /// <summary>
    /// Invoked from JavaScript when a polygon is clicked. Routes the event to the corresponding polygon component.
    /// </summary>
    /// <param name="polygonId">The unique identifier of the clicked polygon.</param>
    [JSInvokable]
    public async Task OnPolygonClicked(Guid polygonId)
    {
        if (_mapPolygonComponents.TryGetValue(polygonId, out var polygonComponent))
        {
            await polygonComponent.Click();
        }
    }

    /// <summary>
    /// Invoked from JavaScript when a polygon's path is modified. Routes the event to the corresponding polygon component.
    /// </summary>
    /// <param name="polygonId">The unique identifier of the polygon.</param>
    /// <param name="paths">The updated polygon path coordinates.</param>
    [JSInvokable]
    public async Task OnPolygonPathChange(Guid polygonId, List<List<LatLngLiteral>> paths)
    {
        if (_mapPolygonComponents.TryGetValue(polygonId, out var polygonComponent))
        {
            await polygonComponent.PathChanged(paths);
        }
    }
    
    internal void AddMarker(MarkerComponent marker)
    {
        _mapComponents.TryAdd(marker.Guid, marker);
        OnMarkersChanged.InvokeAsync();
    }
    
    internal void RemoveMarker(MarkerComponent marker)
    {
        _mapComponents.Remove(marker.Guid);
        OnMarkersChanged.InvokeAsync();
    }

        internal void AddPolygon(PolygonComponent poly)
    {
        _mapPolygonComponents.TryAdd(poly.Guid, poly);
        OnPolygonsChanged.InvokeAsync();
    }
    
    internal void RemovePolygon(PolygonComponent poly)
    {
        _mapPolygonComponents.Remove(poly.Guid);
        OnPolygonsChanged.InvokeAsync();
    }

    /// <summary>
    /// Disposes the map and all associated components, cleaning up JavaScript interop resources.
    /// </summary>
    public async ValueTask DisposeAsync()
    {
        // Mark components as disposed, since they will be removed by disposing the MapRef.
        foreach (var component in _mapComponents)
        {
            component.Value.IsDisposed = true;
        }

        foreach (var component in _mapPolygonComponents)
        {
            component.Value.IsDisposed = true;
        }

        if (MapRef != null)
        {
            await MapRef.DisposeAsync();
        }

        CallbackRef?.Dispose();
    }

}